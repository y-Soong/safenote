spring.profiles.active=local

# MyBatis \uC124\uC815
mybatis.mapper-locations=classpath:mapper/**/*.xml
#mybatis.type-aliases-package=com.prafta.app.dto
#mybatis.type-aliases-package=com.prafta.app.login.dto, com.prafta.app.common.dto, com.prafta.web.user.dto

# MyBatis SQL Log Print
logging.level.com.prafta=WARN
logging.level.org.mybatis=DEBUG
logging.level.org.apache.ibatis=DEBUG

# JDBC Parameter
logging.level.jdbc.sqlonly=DEBUG
logging.level.jdbc.sqltiming=DEBUG

spring.servlet.multipart.max-file-size=10MB
spring.servlet.multipart.max-request-size=50MB

spring.mvc.pathmatch.matching-strategy=ant_path_matcher
mybatis.configuration.map-underscore-to-camel-case=true