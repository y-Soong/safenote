package com.prafta.app.chkLst.chkLst01.controller;

import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

import org.springframework.http.HttpStatus;
import org.springframework.http.MediaType;
import org.springframework.http.ResponseEntity;
import org.springframework.web.bind.annotation.ModelAttribute;
import org.springframework.web.bind.annotation.PostMapping;
import org.springframework.web.bind.annotation.RequestBody;
import org.springframework.web.bind.annotation.RequestHeader;
import org.springframework.web.bind.annotation.RequestMapping;
import org.springframework.web.bind.annotation.RequestParam;
import org.springframework.web.bind.annotation.RestController;
import org.springframework.web.multipart.MultipartFile;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.prafta.app.chkLst.chkLst01.dto.AppChkLst01ReqDto;
import com.prafta.app.chkLst.chkLst01.dto.InspectItemDto;
import com.prafta.app.chkLst.chkLst01.dto.SaveInspectResultReq;
import com.prafta.app.chkLst.chkLst01.service.AppChkLst01Service;
import com.prafta.common.annotation.NoAuth;
import com.prafta.common.exception.CmmApiException;
import com.prafta.common.security.JwtUtil;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Slf4j
@NoAuth
@RestController
@RequestMapping("/chkLst01")
@RequiredArgsConstructor // 롬복이 final 필드로 생성자 자동 생성
public class AppChkLst01Controller {
	
	private final AppChkLst01Service appChkLst01Service;
	private final ObjectMapper objectMapper;
	private final JwtUtil jwtUtil;
	
	/* 공통코드 조회 */
    @PostMapping("/getChkLstInfo")
    public ResponseEntity<?> getChkLstInfo(@RequestBody AppChkLst01ReqDto dto, @RequestHeader(value = "Authorization", required = false) String authorization) {
    	Map<String, Object> tokenInfo = jwtUtil.getAllClaimsAsMap(authorization);
    	
		List<Map<String, Object>> retList = appChkLst01Service.selectChkLstInfo(dto, tokenInfo);
    	
    	if(retList == null) {
    		throw new CmmApiException("조회결과가 없습니다.");
    	}
    	
    	return ResponseEntity.status(HttpStatus.OK).body(retList);
    }
    
    @PostMapping(value = "/save-inspect-result", consumes = MediaType.MULTIPART_FORM_DATA_VALUE)
    public ResponseEntity<?> saveInspectResult(@ModelAttribute SaveInspectResultReq request, @RequestParam(required = false) Map<String, MultipartFile> file) {

        try {
            // 1) MultipartFile → JSON String
            String itemsJson = null;
            if (request.getItems() != null && !request.getItems().isEmpty()) {
                itemsJson = new String(
                        request.getItems().getBytes(),
                        java.nio.charset.StandardCharsets.UTF_8
                );
            } else {
                return ResponseEntity.badRequest()
                        .body(Map.of("error", "items 데이터가 비어 있습니다."));
            }

            System.out.println("siteCd :: " + request.getSiteCd());
            System.out.println("chkptCd :: " + request.getChkptCd());
            System.out.println("itemsJson :: " + itemsJson);

            // 2) JSON 파싱
            JsonNode node = objectMapper.readTree(itemsJson);
            List<InspectItemDto> items = new ArrayList<>();
            if (node.isArray()) {
                for (JsonNode n : node) {
                    items.add(objectMapper.treeToValue(n, InspectItemDto.class));
                }
            }

            // 3) 파일 매칭
            Pattern p = Pattern.compile("^files\\[(.+)]$");
            Map<String, MultipartFile> fileByItemCd = new HashMap<>();
            if (file != null) {
                for (Map.Entry<String, MultipartFile> e : file.entrySet()) {
                	System.out.println("e :: " + e);
                    Matcher m = p.matcher(e.getKey());
                    
                    if (m.find()) {
                        fileByItemCd.put(m.group(1), e.getValue());
                    }
                }
            }

            String projectRoot = System.getProperty("user.dir");
            Path uploadRoot = Paths.get(
                    projectRoot, "uploads",
                    request.getCmpnyCd(), request.getSiteCd(), request.getChkptCd()
            );
            Files.createDirectories(uploadRoot);

            for (InspectItemDto it : items) {
                MultipartFile img = fileByItemCd.get(it.getItemCd());
                System.out.println("it :: " + it);
                System.out.println("img :: " + img);
                if (img != null && !img.isEmpty()) {
                    String originalFilename = img.getOriginalFilename();
                    String extension = "";

                    if (originalFilename != null && originalFilename.contains(".")) {
                        extension = originalFilename.substring(originalFilename.lastIndexOf("."));
                        System.out.println("extension :: " + extension);
                    }

                    String saveFileName = it.getItemCd() + extension;
                    System.out.println("saveFileName :: " + saveFileName);

                    Path savePath = uploadRoot.resolve(saveFileName);
                    Files.createDirectories(savePath.getParent());
                    img.transferTo(savePath.toFile());

                    System.out.println("Saved file: " + savePath.toAbsolutePath());
                }
            }

            return ResponseEntity.ok(
                    Map.of("message", "파일 저장 완료", "uploadPath", uploadRoot.toString())
            );

        } catch (Exception e) {
            e.printStackTrace();
            return ResponseEntity.status(HttpStatus.INTERNAL_SERVER_ERROR)
                    .body(Map.of("error", e.getMessage()));
        }
    }
}
