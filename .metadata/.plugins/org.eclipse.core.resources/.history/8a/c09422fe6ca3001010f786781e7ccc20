<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.common.cmm.login.mapper.LoginMapper">

    <select id="getLoginUser" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.getLoginUser */
	SELECT 
		CMPNY_CD
		, USER_ID
		, USER_NM
		, USER_PW
		, AUTH_CD
		, MBL_NO
		, EMAIL
		, INSERT_NO
		, INSERT_DATE
		, UPDATE_NO
		, UPDATE_DATE
	FROM TB_USER
	WHERE 1=1
	  AND USER_ID = #{userId}
	  <!-- 
	  AND USER_PW = #{userPw}
	   -->
	  AND USE_YN = 'Y'
    </select>
    
    <insert id="insertUserInfo">
    /* LoginMapper.insertUserInfo */
    INSERT INTO TB_USER (
    	CMPNY_CD
    	, USER_ID
    	, USER_NM
    	, USER_PW
    	, SITE_CD
    	, AUTH_CD
    	, MBL_NO
    	, EMAIL
    	, GENDER
    	, BIRTH_DT
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
   	)
   	VALUES(
   		#{cmpnyCd}
   		, #{userId}
   		, #{userNm}
   		, #{userPw}
   		, #{siteCd}
   		, IFNULL(#{authCd}, '100')
   		, FN_ENCRYPT(REPLACE(#{mblNo}, '-', ''))
   		, FN_ENCRYPT(#{email})
   		, #{gender}
   		, FN_ENCRYPT(#{birthDt})
   		, 'Y'
   		, 'SYSTEM'
   		, NOW()
   		, 'SYSTEM'
   		, NOW()
   	)
   	<!-- 
   	ON DUPLICATE KEY UPDATE
	    USER_NM     = VALUES(USER_NM),
	    AUTH_CD     = VALUES(AUTH_CD),
	    MBL_NO      = VALUES(MBL_NO),
	    EMAIL       = VALUES(EMAIL),
	    GENDER      = VALUES(GENDER),
	    BIRTH_DT    = VALUES(BIRTH_DT),
	    USE_YN      = 'Y',
	    UPDATE_NO   = 'SYSTEM',
	    UPDATE_DATE = NOW()
     -->
    </insert>
    
    <insert id="insertUserSiteAuth">
    /* LoginMapper.insertUserSiteAuth */
    INSERT INTO TB_USER_SITE_AUTH (
    	CMPNY_CD
    	, USER_ID
    	, SITE_CD
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
    ) VALUES (
    	#{cmpnyCd}
    	, #{userId}
    	, #{siteCd}
    	, 'Y'
    	, #{userId}
    	, NOW()
    	, #{userId}
    	, NOW()
    )
    </insert>
    
    <select id="selectRequiredTermsList" resultType="map">
    /* LoginMapper.selectRequiredTermsList */
    SELECT 
		A.SYST_VAL_D_CD AS TERMS_ID
	    , A.SYST_VAL_D_NM AS TERMS_NM
	    , B.TERMS_VERSION AS TERMS_VERSION
	FROM TB_SYST_VAL_D A
	     INNER JOIN TB_TERMS B
			ON (
				A.SYST_VAL_D_CD = B.TERMS_ID
			AND B.REQUIRED_YN = 'Y'
	        AND B.USE_YN = 'Y'
	        )
	WHERE A.SYST_VAL_CD = 'SYS008'						/* 이용약관 코드 조회 */
    </select>
    
    <insert id="insertTermsUserAgrMgmt">
    /* LoginMapper.insertTermsUserAgrMgmt */
    INSERT INTO TB_TERMS_USER_AGR_MGMT (
    	USER_ID
    	, TERMS_ID
    	, TERMS_VERSION
    	, AGR_YN
    	, INSERT_NO
    	, INSERT_DATE
    )
    VALUES (
    	#{userId}
    	, #{termsId}
    	, #{termsVersion}
    	, #{agrYn}
    	, #{userId}
    	, NOW()
    )
    </insert>
    
    <select id="selectUserTermsAgrChk" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.selectUserTermsAgrChk */
    SELECT 
		A.TERMS_ID
	    , CASE
			WHEN A.TERMS_VERSION = B.TERMS_VERSION
				THEN 'Y'
			ELSE 'N'
		END USER_TEMRS_AGR_YN    
	FROM TB_TERMS A
	     LEFT OUTER JOIN TB_TERMS_USER_AGR_MGMT B
			ON (
				A.TERMS_ID = B.TERMS_ID
			AND A.TERMS_VERSION = B.TERMS_VERSION
	        AND B.USER_ID = #{userId}
	        )
	WHERE 1=1
	  AND A.USE_YN = 'Y'
    </select>
</mapper>