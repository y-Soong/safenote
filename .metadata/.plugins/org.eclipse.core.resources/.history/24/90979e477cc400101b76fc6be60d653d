package com.prafta.app.chkLst.chkLst01.service.impl;

import java.nio.file.Files;
import java.nio.file.Path;
import java.nio.file.Paths;
import java.time.LocalDate;
import java.time.format.DateTimeFormatter;
import java.util.ArrayList;
import java.util.HashMap;
import java.util.List;
import java.util.Map;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

import org.springframework.beans.factory.annotation.Autowired;
import org.springframework.http.ResponseEntity;
import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.prafta.app.chkLst.chkLst01.dto.AppChkLst01ReqDto;
import com.prafta.app.chkLst.chkLst01.dto.InspectItemDto;
import com.prafta.app.chkLst.chkLst01.dto.SaveInspectResultReq;
import com.prafta.app.chkLst.chkLst01.mapper.AppChkLst01Mapper;
import com.prafta.app.chkLst.chkLst01.service.AppChkLst01Service;

import lombok.extern.slf4j.Slf4j;

@Slf4j
@Service
public class AppChkLst01ServiceImpl implements AppChkLst01Service {
	private final AppChkLst01Mapper appChkLst01Mapper;
	
	@Autowired
	private ObjectMapper objectMapper;
	
	public AppChkLst01ServiceImpl(AppChkLst01Mapper appChkLst01Mapper) {
		this.appChkLst01Mapper = appChkLst01Mapper;
	}
	
	public List<Map<String, Object>> selectChkLstInfo(AppChkLst01ReqDto dto, Map<String, Object> tokenInfo) {
		return appChkLst01Mapper.selectChkLstInfo(dto, tokenInfo);
	}
	
	public void saveInspectResult(SaveInspectResultReq request, Map<String, MultipartFile> file, Map<String, Object> tokenInfo) {
		try {
            // 1) MultipartFile ˇć JSON String
            String itemsJson = null;
            if (request.getItems() != null && !request.getItems().isEmpty()) {
                itemsJson = new String(
                        request.getItems().getBytes(),
                        java.nio.charset.StandardCharsets.UTF_8
                );
            }

            // 2) JSON ĆÄ˝Ě
            JsonNode node = objectMapper.readTree(itemsJson);
            List<InspectItemDto> items = new ArrayList<>();
            if (node.isArray()) {
                for (JsonNode n : node) {
                    items.add(objectMapper.treeToValue(n, InspectItemDto.class));
                }
            }

            // 3) ĆÄŔĎ ¸ĹÄŞ
            Pattern p = Pattern.compile("^files\\[(.+)]$");
            Map<String, MultipartFile> fileByItemCd = new HashMap<>();
            if (file != null) {
                for (Map.Entry<String, MultipartFile> e : file.entrySet()) {
                    Matcher m = p.matcher(e.getKey());
                    
                    if (m.find()) {
                        fileByItemCd.put(m.group(1), e.getValue());
                    }
                }
            }
            
            String today = LocalDate.now().format(DateTimeFormatter.ofPattern("yyyyMMdd"));

            String projectRoot = System.getProperty("user.dir");
            Path uploadRoot = Paths.get(
                    projectRoot, "uploads",
                    request.getCmpnyCd(), today, request.getSiteCd(), request.getChkptCd()
            );
            Files.createDirectories(uploadRoot);

            for (InspectItemDto it : items) {
                MultipartFile img = fileByItemCd.get(it.getItemCd());
                if (img != null && !img.isEmpty()) {
                    String originalFilename = img.getOriginalFilename();
                    String extension = "";

                    if (originalFilename != null && originalFilename.contains(".")) {
                        extension = originalFilename.substring(originalFilename.lastIndexOf("."));
                    }

                    String saveFileName = it.getItemCd() + extension;

                    Path savePath = uploadRoot.resolve(saveFileName);
                    Files.createDirectories(savePath.getParent());
                    img.transferTo(savePath.toFile());
                }
            }
        } catch (Exception e) {
            e.printStackTrace();
        }
	}
}
