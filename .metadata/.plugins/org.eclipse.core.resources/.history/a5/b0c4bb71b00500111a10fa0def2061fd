<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.common.cmm.baseinfo.mapper.BaseinfoMapper">

    <select id="selectSystinfoList" parameterType="com.prafta.common.cmm.baseinfo.dto.SystInfoListQuery" resultType="com.prafta.common.cmm.baseinfo.vo.SystInfo">
    /* BaseinfoMapper."selectSystinfoList" */
    SELECT
    	A.SYST_VAL_CD			AS systValCd
		, A.SYST_VAL_NM			AS systValNm
		, A.SORT_IDX			AS sortIdx
		, A.SYST_VAL_D_CD		AS systValDCd
		, A.SYST_VAL_D_NM		AS systValDNm
   	FROM
   	(
	    SELECT 
			A.SYST_VAL_CD
		    , A.SYST_VAL_NM
		    , B.SORT_IDX AS SORT_IDX
		    , B.SYST_VAL_D_CD
		    , B.SYST_VAL_D_NM
		FROM TB_SYST_VAL_M A 
			 INNER JOIN TB_SYST_VAL_D B
			 	ON (
			 		A.SYST_VAL_CD = B.SYST_VAL_CD
			 		<!-- 
		 		AND (B.VAL_D_INFO_1 != 'S' OR B.VAL_D_INFO_1 IS NULL)
		 		 -->
			 	)
		WHERE 1=1
		  <if test="systCodeList != null and systCodeList != ''">
		  	AND A.SYST_VAL_CD IN
		  	<foreach collection="systCodeList" item="item" open="(" separator="," close=")">
		  		#{item}
		  	</foreach>
		  </if>
		  AND A.USE_YN = 'Y'
		  AND A.USE_YN = B.USE_YN
		  
		UNION ALL
		
		SELECT 
		    A.SYST_VAL_CD
		    , A.SYST_VAL_NM
		    , 0 AS SORT_IDX
		    , NULL AS SYST_VAL_D_CD
		    , '전체' AS SYST_VAL_D_NM
		FROM TB_SYST_VAL_M A
		WHERE 1=1
		  AND A.USE_YN = 'Y'
		  <if test="systCodeList != null and systCodeList != ''">
		  	AND A.SYST_VAL_CD IN
		  	<foreach collection="systCodeList" item="item" open="(" separator="," close=")">
		  		#{item}
		  	</foreach>
		  </if>
	) A
	WHERE 1=1		
	ORDER BY A.SYST_VAL_CD, A.SORT_IDX, A.SYST_VAL_D_CD
    </select>

    <select id="selectSystinfo" parameterType="com.prafta.common.cmm.baseinfo.dto.SystInfoQry" resultType="com.prafta.common.cmm.baseinfo.vo.SystInfo">
    /* BaseinfoMapper."selectSystinfo" */
    SELECT 
		A.SYST_VAL_CD						AS systValCd
	    , A.SYST_VAL_NM						AS systValNm
	    , B.SORT_IDX 						AS sortIdx		
	    , B.SYST_VAL_D_CD					AS systValDCd
	    , B.SYST_VAL_D_NM					AS systValDNm
	FROM TB_SYST_VAL_M A 
		 INNER JOIN TB_SYST_VAL_D B
		 	ON (
		 		A.SYST_VAL_CD = B.SYST_VAL_CD
	 		AND A.USE_YN = B.USE_YN
 			<if test="codeD != null and codeD != ''">
				AND B.SYST_VAL_D_CD = #{codeD}
			</if>
			<if test="nameD != null and nameD != ''">
				AND B.SYST_VAL_D_NM LIKE CONCAT('%', #{nameD}, '%')
			</if>
		 	)
	WHERE 1=1
	  AND A.USE_YN = 'Y'
	  <if test="code != null and code != ''">
		AND A.SYST_VAL_CD = #{code}
	  </if>
	ORDER BY A.SYST_VAL_CD, B.SORT_IDX, B.SYST_VAL_D_CD
    </select> 
    
    <select id="selectBaseinfoList" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseInfoListQuery" resultType="com.prafta.common.cmm.baseinfo.vo.BaseInfo">
    /* BaseinfoMapper."selectBaseinfoList" */
    SELECT
    	A.BAIM_VAL_CD				AS baimValCd
		, A.BAIM_VAL_NM				AS baimValNm
		, A.SORT_IDX				AS sortIdx
		, A.BAIM_VAL_D_CD			AS baimValDCd
		, A.BAIM_VAL_D_NM			AS baimBalDNm
   	FROM
   	(
	    SELECT 
			A.BAIM_VAL_CD
		    , A.BAIM_VAL_NM
		    , B.SORT_IDX AS SORT_IDX
		    , B.BAIM_VAL_D_CD
		    , B.BAIM_VAL_D_NM
		FROM TB_BAIM_VAL_M A 
			 INNER JOIN TB_BAIM_VAL_D B
			 	ON (
			 		A.CMPNY_CD = B.CMPNY_CD
		 		AND A.BAIM_VAL_CD = B.BAIM_VAL_CD
			 	AND B.VAL_D_INFO_1 != 'manage'									<!-- 시스템관리용 코드는 제외 -->
			 	)
		WHERE 1=1
		  AND A.CMPNY_CD = #{cmpnyCd}
		  <if test="baseCodeList != null and baseCodeList != ''">
		  	AND A.BAIM_VAL_CD IN
		  	<foreach collection="baseCodeList" item="item" open="(" separator="," close=")">
		  		#{item}
		  	</foreach>
		  </if>
		  AND A.USE_YN = 'Y'
		  AND A.USE_YN = B.USE_YN
		  
		UNION ALL
		
		SELECT 
		    A.BAIM_VAL_CD
		    , A.BAIM_VAL_NM
		    , 0 AS SORT_IDX
		    , NULL AS BAIM_VAL_D_CD
		    , '전체' AS BAIM_VAL_D_NM
		FROM TB_BAIM_VAL_M A
		WHERE 1=1
		  AND A.CMPNY_CD = #{cmpnyCd}
		  AND A.USE_YN = 'Y'
		  <if test="baseCodeList != null and baseCodeList != ''">
		  	AND A.BAIM_VAL_CD IN
		  	<foreach collection="baseCodeList" item="item" open="(" separator="," close=")">
		  		#{item}
		  	</foreach>
		  </if>
	) A
	WHERE 1=1		
	ORDER BY A.BAIM_VAL_CD, A.SORT_IDX, A.BAIM_VAL_D_CD
    </select>   
    
    <select id="selectBaseinfo" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseInfoQry" resultType="com.prafta.common.cmm.baseinfo.vo.BaseInfo">
    /* BaseinfoMapper."selectBaseinfo" */
    SELECT 
		A.BAIM_VAL_CD				AS baimValCd
		, A.BAIM_VAL_NM				AS baimValNm
		, B.SORT_IDX				AS sortIdx
		, B.BAIM_VAL_D_CD			AS baimValDCd
		, B.BAIM_VAL_D_NM			AS baimBalDNm
	FROM TB_BAIM_VAL_M A
		 INNER JOIN TB_BAIM_VAL_D B
			ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.BAIM_VAL_CD = B.BAIM_VAL_CD
	        AND A.USE_YN = B.USE_YN
	        <if test="param.codeD != null and param.codeD != ''">
				AND B.BAIM_VAL_D_CD = #{param.codeD}
			</if>
			<if test="param.nameD != null and param.nameD != ''">
				AND B.BAIM_VAL_D_NM LIKE CONCAT('%', #{param.nameD}, '%')
			</if>
			AND B.VAL_D_INFO_1 != 'manage'									<!-- 시스템관리용 코드는 제외 -->
	        )
	WHERE A.CMPNY_CD = #{token.gv_cmpnyCd}
	  AND A.USE_YN = 'Y'
	  <if test="param.code != null and param.code != ''">
		AND A.BAIM_VAL_CD = #{param.code}
	  </if>
	ORDER BY A.BAIM_VAL_CD, B.SORT_IDX, B.BAIM_VAL_D_CD
    </select>
    
	<select id="selectCmpnyInfo" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.selectCmpnyInfo */
    SELECT *
	FROM TB_CMPNY
	WHERE 1=1
	  AND CMPNY_CD = #{cmpnyCd}
    </select>
    
    <select id="selectUserIdDupleChk" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.selectUserIdDupleChk */
	(
		SELECT 
			'N' AS UNIQUE_YN
		FROM TB_USER
		WHERE 1=1
		  AND CMPNY_CD = #{cmpnyCd}
		  AND USER_ID = #{userId}
	)
	UNION
	(
		SELECT 'Y' FROM DUAL
	)
	LIMIT 1;
    </select>
    
    <select id="selectMblUniqChk" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="int">
    /* BaseinfoMapper."selectMblUniqChk" */
    SELECT COUNT(*)
	FROM TB_USER
	WHERE REPLACE(MBL_NO, '-', '') = FN_ENCRYPT(REPLACE(#{mblNo}, '-', ''))
    </select>
    
    <insert id="insertSmsAuthReq">
    /* LoginMapper.insertSmsAuthReq */
    INSERT INTO TB_SMS_AUTH_CODE (
		MBL_NO
	    , AUTH_CD
	    , EXPIRED_AT
	)
	VALUES (
		#{mblNo}
	    , #{certNo}
	    , DATE_ADD(NOW(), INTERVAL 1 MINUTE)
	)
    </insert>
    
    <select id="selectCertNoSmsId" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.selectCertNoSmsId */
    SELECT 
		*
	FROM TB_SMS_AUTH_CODE
	WHERE 1=1
	  AND MBL_NO = #{mblNo}
	  AND AUTH_CD = #{certNo}
	  AND EXPIRED_AT <![CDATA[ >= ]]> NOW()
	  AND VERIFIED_YN = 'N'
    </select>
    
    <update id="updateSmsAuthReq">
    /* LoginMapper.updateSmsAuthReq */
    UPDATE TB_SMS_AUTH_CODE
	SET 
	    VERIFIED_YN = 'Y',
	    UPDATE_NO = 'SYSTEM',
	    UPDATE_DATE = NOW()
	WHERE 
		SMS_ID = #{smsId}
	    AND MBL_NO = #{mblNo}
	    AND AUTH_CD = #{certNo}
	    AND EXPIRED_AT <![CDATA[ >= ]]> NOW()
	    AND VERIFIED_YN = 'N'
    </update>
    
    <select id="selectSiteInfoList" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectSiteInfoList" */
    SELECT 
    	A.*
	FROM TB_SITE A
		 
		 <if test="userId != null and userId != ''">
		 INNER JOIN TB_USER_SITE_AUTH B
		 	ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.SITE_CD = B.SITE_CD
			AND B.USER_ID = #{userId}
            )
		 </if>
			
	WHERE 1=1
	  AND A.CMPNY_CD = #{cmpnyCd}
	  AND A.USE_YN = 'Y'
	  AND (
	    A.END_DATE IS NULL OR
	  	A.END_DATE <![CDATA[ >= ]]> date_format(NOW(), '%y%m%d')
  	  )
  	  <if test="siteNo != null and siteNo != ''">
  	  	AND A.SITE_NO = #{siteNo}
  	  </if>
  	  <if test="siteNm != null and siteNm != ''">
  	  	AND A.SITE_NM LIKE CONCAT('%', #{siteNm}, '%')
  	  	
  	  </if>
    </select>
    
    <select id="selectSiteNodeList" parameterType="com.prafta.common.cmm.baseinfo.dto.SiteNodeListQry" resultType="com.prafta.common.cmm.baseinfo.vo.SiteNodeInfo">
    /* BaseinfoMapper."selectSiteNodeList" */
    SELECT 
    	A.CMPNY_CD				AS cmpnyCd
	    , A.SITE_CD				AS siteCd
	    , A.NODE_CD				AS nodeCd
	    , A.NODE_NM				AS nodeNm
	    , A.NODE_TYPE			AS nodeType
	    , A.PARENT_NODE_CD		AS parentNodeCd
	    , A.PARENT_NODE_NM 		AS parentNodeNm
	    , A.SELF_ATTD_APPRV_YN	AS selfAttdApprvYn
    FROM
    (
		SELECT 
			A.CMPNY_CD
		    , A.SITE_CD
		    , A.NODE_CD
		    , A.NODE_NM
		    , A.NODE_TYPE
		    , PARENT_NODE_CD
		    , FNC_CMM_INFO_SRCH(A.CMPNY_CD, 'NODE', A.SITE_CD, A.PARENT_NODE_CD) AS PARENT_NODE_NM
		    , SELF_ATTD_APPRV_YN
		  FROM TB_SITE_NODE A
		 WHERE A.CMPNY_CD = #{param.cmpnyCd}
	 	   AND A.SITE_CD = #{param.siteCd}
	 	   <if test="param.nodeCd != null and param.nodeCd != ''">
	 	   	AND A.NODE_CD = #{param.nodeCd}
	 	   </if>
	 	   <if test="param.nodeNm != null and param.nodeNm != ''">
	 	   	AND A.NODE_NM LIKE CONCAT('%', #{param.nodeNm}, '%')
	 	   </if>
	 	   <if test="param.nodeType != null and param.nodeType != ''">
	 	   	AND A.NODE_TYPE = #{param.nodeType}
	 	   </if>
	) A
	WHERE 1=1
	  <if test="param.parentNodeNm != null and param.parentNodeNm != ''">
	  	AND A.PARENT_NODE_NM LIKE CONCAT('%', #{param.parentNodeNm}, '%')
	  </if>
	   
    </select>
        
    <select id="selectWebMenuList" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectWebMenuList" */
    SELECT 
		A.CMPNY_CD
	    , A.USER_ID
	    , A.USER_NM
	    , B.MENU_M_ID
	    , B.MENU_D_ID 	AS PATH
	    , B.MENU_D_ID 	AS NAME
	    , B.MENU_VIEW 	AS VIEW
	    , B.MENU_NM 	AS TITLE
	FROM TB_USER A
	     INNER JOIN (
			SELECT 
				A.CMPNY_CD
				, A.AUTH_CD
				, B.MENU_M_ID
				, A.MENU_D_ID
				, B.MENU_VIEW
				, B.MENU_NM
			FROM TB_SYST_AUTH_MENU A
				 INNER JOIN (
					SELECT 
						A.MENU_M_ID
						, B.MENU_D_ID
						, B.MENU_VIEW
						, B.MENU_NM
	                    , A.USE_YN
					FROM TB_SYST_MENU_M A
						 INNER JOIN TB_SYST_MENU_D B
							ON (
								A.MENU_M_ID = B.MENU_M_ID
							AND A.USE_YN = B.USE_YN
							)
					WHERE A.USE_YN = 'Y'
					ORDER BY A.MENU_IDX, B.MENU_IDX
				 ) B
					ON (
						A.MENU_D_ID = B.MENU_D_ID
					AND A.USE_YN = B.USE_YN
					)
	     ) B
			ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.AUTH_CD = B.AUTH_CD
	        )
	WHERE 1=1
	  AND A.CMPNY_CD = #{cmpnyCd}	  
	  AND A.USER_ID = #{userId}
    </select>
    
    <select id="selectAppMenuList" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectAppMenuList" */
    SELECT 
		A.MENU_M_ID
		, B.MENU_D_ID 	AS PATH
		, B.MENU_D_ID 	AS NAME
		, B.MENU_VIEW 	AS VIEW
		, B.MENU_NM 	AS TITLE
	FROM TB_SYST_MENU_M A
	     INNER JOIN TB_SYST_MENU_D B
			ON (
				A.MENU_M_ID = B.MENU_M_ID
			AND A.USE_YN = B.USE_YN
	        )
	WHERE A.MENU_SRC = '002'				/* APP MENU TYPE */
	  AND A.USE_YN = 'Y'
    </select>
	
	<select id="selectMenuList" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectMenuList" */
    SELECT 
		B.MENU_M_ID AS KEY_ID
	    , CONCAT(B.MENU_M_ID, '_',B.MENU_SUB_IDX) AS ID
	    , B.TOP_MENU_NM
        , B.SIDE_MENU_NM
	    , B.MENU_D_ID AS ROUTE
	    , B.BTN_SRCH
	    , B.BTN_NEW
		, B.BTN_DELT
		, B.BTN_SAVE
		, B.BTN_EXCL
	FROM TB_USER A
	     INNER JOIN (
			SELECT 
				A.CMPNY_CD
				, A.AUTH_CD
				, B.MENU_M_ID
				, A.MENU_D_ID
				, B.MENU_VIEW
				, B.TOP_MENU_NM
				, B.SIDE_MENU_NM
	            , A.BTN_SRCH
	            , A.BTN_NEW
	            , A.BTN_DELT
	            , A.BTN_SAVE
	            , A.BTN_EXCL
	            , B.MENU_IDX
	            , B.MENU_SUB_IDX
			FROM TB_SYST_AUTH_MENU A
				 INNER JOIN (
					SELECT 
						A.MENU_M_ID
						, A.MENU_NM AS TOP_MENU_NM
						, B.MENU_D_ID
						, B.MENU_VIEW
						, B.MENU_NM	AS SIDE_MENU_NM
	                    , A.USE_YN
	                    , A.MENU_IDX
	                    , B.MENU_IDX AS MENU_SUB_IDX
					FROM TB_SYST_MENU_M A
						 INNER JOIN TB_SYST_MENU_D B
							ON (
								A.MENU_M_ID = B.MENU_M_ID
							AND A.USE_YN = B.USE_YN
							)
					WHERE A.USE_YN = 'Y'
					  AND A.MENU_SRC = #{menuSrc}
					ORDER BY A.MENU_IDX, B.MENU_IDX
				 ) B
					ON (
						A.MENU_D_ID = B.MENU_D_ID
					AND A.USE_YN = B.USE_YN
					)
	     ) B
			ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.AUTH_CD = B.AUTH_CD
	        )
	WHERE 1=1
	  AND A.CMPNY_CD = #{cmpnyCd}
	  AND A.USER_ID = #{userId}
	  AND A.USE_YN = 'Y'
    	
    </select>
    
    <select id="selectUserIdInfo" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectUserIdInfo" */
    SELECT *
    FROM TB_USER
    WHERE 1=1
      AND USER_NM = #{userNm}
      AND MBL_NO = FN_ENCRYPT(REPLACE(#{mblNo}, '-', ''))
    </select>
    
    <update id="updateUserPw">
    /* BaseinfoMapper."updateUserPw" */
    UPDATE TB_USER
	SET USER_PW = #{userPw}
	WHERE 1=1
	  AND CMPNY_CD = #{cmpnyCd}
	  AND USER_ID = #{userId}
    </update>
    
    <select id="selectTermsDInfo" parameterType="com.prafta.common.cmm.baseinfo.dto.BaseinfoCmmReq" resultType="map">
    /* BaseinfoMapper."selectTermsDInfo" */
    SELECT * 
	FROM TB_TERMS
	WHERE TERMS_ID = #{termsId}
    </select>
    
</mapper>