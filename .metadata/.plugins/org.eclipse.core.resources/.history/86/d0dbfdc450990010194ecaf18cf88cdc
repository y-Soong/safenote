<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.web.user.user01.mapper.User01Mapper">

    <select id="selectUserInfoList" parameterType="com.prafta.web.user.user01.dto.User01ReqDto" resultType="map">
    /* User01Mapper.selectUserInfoList */
	SELECT 
		A.CMPNY_CD
        , A.USER_ID
        , A.USER_NM
        , A.AUTH_CD
        , A.SITE_CD
        , C.SITE_NM
        , FN_DECRYPT(A.MBL_NO) AS MBL_NO
        , FN_DECRYPT(A.BIRTH_DT) AS BIRTH_DT
        , FN_DECRYPT(A.EMAIL) AS EMAIL
        , A.GENDER
        , A.USE_YN
        , IFNULL(B.SITE_NM_LIST, '') AS SITE_NM_LIST
	FROM TB_USER A
		 LEFT JOIN (
			SELECT 
				A.USER_ID
				, GROUP_CONCAT(B.SITE_NM ORDER BY B.SITE_CD SEPARATOR ',') AS SITE_NM_LIST
			FROM TB_USER_SITE_AUTH A
			     INNER JOIN TB_SITE B
					ON (
						A.CMPNY_CD = B.CMPNY_CD
					AND A.SITE_CD = B.SITE_CD
					)
			WHERE A.USE_YN = 'Y'
			GROUP BY A.USER_ID
		) B
		ON B.USER_ID = A.USER_ID
		INNER JOIN TB_SITE C
		ON (
			A.CMPNY_CD = C.CMPNY_CD
		AND A.SITE_CD = C.SITE_CD
           AND C.USE_YN = 'Y'
           )
	WHERE 1=1
	  AND A.CMPNY_CD = #{gv_cmpnyCd}
	  AND A.AUTH_CD != '999'				/* 시스템관리자 권한 제외 */
	  <if test="sr_userNm != null and sr_userNm != ''">
	  	AND A.USER_NM LIKE CONCAT('%', #{sr_userNm}, '%')
	  </if>
	  <if test="sr_userId != null and sr_userId != ''">
	  	AND A.USER_ID = #{sr_userId}
	  </if>
	  <if test="sr_useYn != null and sr_useYn != ''">
	  	AND A.USE_YN = #{sr_useYn}
	  </if>
	  <if test="sr_siteCd != null and sr_siteCd != ''">
	  	AND A.SITE_CD = #{sr_siteCd}
	  </if>
    </select>
    
	<update id="updateUserPw">
	/* User01Mapper.updateUserPw */
	UPDATE
		TB_USER
	SET
		USER_PW = #{userId}
	WHERE 1=1
	  AND CMPNY_CD = #{cmpnyCd}
	  AND USER_ID = #{userId}
	</update>
	
	<insert id="mergeUserInfo">
	/* User01Mapper.updateUserInfo */
	UPDATE TB_USER 
	SET 
		SITE_CD = #{param.siteCd}
		, AUTH_CD = #{param.authCd}
		, MBL_NO = #{param.mblNo}
		, EMAIL = #{param.email}
		, GENDER = #{param.gender}
		, BIRTH_DT = #{param.birthDt}
		, USE_YN = IFNULL(#{param.useYn}, 'Y')
		, UPDATE_NO = #{token.gv_userId}
		, UPDATE_DATE = NOW()
	WHERE 1=1
	  AND CMPNY_CD = #{param.cmpnyCd}
	  AND USER_ID = #{param.userId}
	
