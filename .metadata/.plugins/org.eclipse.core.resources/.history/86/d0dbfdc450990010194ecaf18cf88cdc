	<select id="selectUserSiteInfo" parameterType="com.prafta.web.user.user01.dto.User01ReqDto" resultType="map">
    /* User01Mapper.selectUserSiteInfo */
    SELECT *
	FROM TB_USER
	WHERE CMPNY_CD = #{sr_cmpnyCd}
	  AND USER_ID = #{sr_userId}
    </select>
    
    <update id="deleteUserSiteAuth">
    /* User01Mapper.deleteUserSiteAuth */
    UPDATE TB_USER_SITE_AUTH
   	SET 
   		USE_YN = 'N'
   		, UPDATE_NO = #{token.gv_userId}
  		, UPDATE_DATE = NOW()
	WHERE CMPNY_CD = #{param.cmpnyCd}
	  AND USER_ID = #{param.userId}   		
    	
    </update>
    
    <update id="insertUserSiteAuth">
    /* User01Mapper.insertUserSiteAuth */
    INSERT INTO TB_USER_SITE_AUTH (
    	CMPNY_CD
    	, USER_ID
    	, SITE_CD
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
    )
    VALUES (
    	#{param.cmpnyCd}
    	, #{param.userId}
    	, #{param.siteCd}
    	, IFNULL(#{param.useYn}, 'Y')
    	, #{token.gv_userId}
    	, NOW()
    	, #{token.gv_userId}
    	, NOW()
    )
    ON DUPLICATE KEY UPDATE
	    USE_YN        = VALUES(USE_YN)
	    , UPDATE_NO   = VALUES(UPDATE_NO)
	    , UPDATE_DATE = VALUES(UPDATE_DATE)
    </update>
