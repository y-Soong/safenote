<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.web.attd.attd01.mapper.Attd01Mapper">

    <select id="selectSchInfoList" parameterType="com.prafta.web.attd.attd01.dto.SchInfoListQry" resultType="com.prafta.web.attd.attd01.vo.SchInfo">
    /* Attd01Mapper.selectSchInfoList */
    SELECT
	    A.CMPNY_CD          AS cmpnyCd,
	    A.SITE_CD           AS siteCd,
	    A.SCH_CD            AS schCd,
	    A.SCH_NO            AS schNo,
	    A.SCH_TYPE          AS schType,
	
	    A.FST_SCH_STR_TIME  AS fstSchStrTime,
	    A.FST_SCH_STR_END   AS fstSchStrEnd,
	    A.FST_SCH_BRK_HOUR  AS fstSchBrkHour,
	    A.FST_SCH_BRK_YN    AS fstSchBrkYn,
	
	    A.SEC_SCH_STR_TIME  AS secSchStrTime,
	    A.SEC_SCH_STR_END   AS secSchStrEnd,
	    A.SEC_SCH_BRK_HOUR  AS secSchBrkHour,
	    A.SEC_SCH_BRK_YN    AS secSchBrkYn,
	
	    A.USE_YN            AS useYn,
	    A.INSERT_NO         AS insertNo,
	    A.INSERT_DATE       AS insertDate,
	    A.UPDATE_NO         AS updateNo,
	    A.UPDATE_DATE       AS updateDate
	FROM TB_SCH_MGMT A
	WHERE 1=1
	  AND A.CMPNY_CD = #{token.cmpnyCd}
	  <if test="param.siteCd != null and param.siteCd != ''">
	  	AND A.SITE_CD = #{param.siteCd}
	  </if>
	  <if test="param.schCd != null and param.schCd != ''">
	  	AND A.SCH_CD = #{param.schCd}	
	  </if>
	  <if test="param.useYn != null and param.useYn != ''">
	  	AND A.USE_YN  = #{param.useYn}
	  </if>
	</select>
</mapper>