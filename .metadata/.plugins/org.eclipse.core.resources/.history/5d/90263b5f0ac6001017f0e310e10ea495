<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.app.chkLst.chkLst01.mapper.AppChkLst01Mapper">

    <select id="selectChkLstInfo" parameterType="com.prafta.app.chkLst.chkLst01.dto.ChecklistInfoQuery" resultType="com.prafta.app.chkLst.chkLst01.vo.ChecklistInfo">
    /* AppChkLst01Mapper."selectChkLstInfo" */
    SELECT 
		A.CMPNY_CD 					AS cmpnyCd
	    , A.CHKLST_TYPE				AS chklstType
	    , A.CHKPT_DESC				AS chkptDesc
	    , B.INSPECT_ITEM_CD			AS inspectItemCd
	    , B.INSPECT_ITEM_SUBJ		AS inspectItemSubj
	    , 'Y' 						AS inspectValue
	    , B.SORT_IDX				AS sortIdx
	FROM TB_CHKPT_TYPE_MGMT A
	     INNER JOIN TB_CHKPT_INSPECT_ITEM B
	     ON (
			A.CMPNY_CD = B.CMPNY_CD
		AND A.CHKLST_TYPE = B.CHKLST_TYPE
	    AND A.USE_YN = B.USE_YN
	     )
	WHERE 1=1
	  AND A.CMPNY_CD = #{ token.gv_cmpnyCd }
	  AND A.SITE_CD = #{ param.siteCd }
	  AND A.CHKPT_CD = #{ param.chkptCd }
	  AND A.USE_YN = 'Y'
	ORDER BY B.SORT_IDX
    </select>
	
	<insert id="mergeChkptInspectAnswer" parameterType="com.prafta.app.chkLst.chkLst01.dto.ChecklistInfoSave">
	/* AppChkLst01Mapper.mergeChkptInspectAnswer */	
    INSERT INTO TB_CHKPT_INSPECT_ANSWER (
    	CMPNY_CD
    	, INSPECT_ITEM_CD
    	, WORK_DATE
    	, INSPECT_ANSWER_TYPE
    	, ANSWER_DESC
    	, FILE_MGMT_CD
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
   	)
   	VALUES(
   		#{token.gv_cmpnyCd}
   		, #{param.inspectItemCd}
   		, #{param.inspectAnswerType}
   		, #{param.answerDesc}
   		, #{param.fileMgmtCd}		
		, #{token.gv_userId}
		, now()
		, #{token.gv_userId}
		, now() 
   	)
   	ON DUPLICATE KEY UPDATE
	    INSPECT_ANSWER_TYPE = VALUES(INSPECT_ANSWER_TYPE)
	    , ANSWER_DESC 		= VALUES(ANSWER_DESC)
	    , FILE_MGMT_CD		= VALUES(FILE_MGMT_CD)
	    , UPDATE_NO   		= #{token.gv_userId}
	    , UPDATE_DATE 		= NOW()
	</insert>
</mapper>