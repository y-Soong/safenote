package com.prafta.app.chkLst.chkLst01.service.impl;

import java.util.*;
import java.util.regex.Matcher;
import java.util.regex.Pattern;

import org.springframework.stereotype.Service;
import org.springframework.web.multipart.MultipartFile;

import com.fasterxml.jackson.databind.JsonNode;
import com.fasterxml.jackson.databind.ObjectMapper;
import com.prafta.app.chkLst.chkLst01.dto.AppChkLst01ReqDto;
import com.prafta.app.chkLst.chkLst01.dto.SaveInspectResultReq;
import com.prafta.app.chkLst.chkLst01.mapper.AppChkLst01Mapper;
import com.prafta.app.chkLst.chkLst01.service.AppChkLst01Service;
import com.prafta.common.cmm.file.dto.FileInfo;
import com.prafta.common.cmm.file.dto.FileSaveQuery;
import com.prafta.common.cmm.file.mapper.FileMapper;
import com.prafta.common.cmm.file.service.FileService;

import lombok.RequiredArgsConstructor;
import lombok.extern.slf4j.Slf4j;

@Slf4j
@Service
@RequiredArgsConstructor
public class AppChkLst01ServiceImpl implements AppChkLst01Service {

    private final AppChkLst01Mapper appChkLst01Mapper;
    private final ObjectMapper objectMapper;
    private final FileService fileService;
    private final FileMapper fileMapper;

    @Override
    public List<Map<String, Object>> selectChkLstInfo(AppChkLst01ReqDto dto,
                                                      Map<String, Object> tokenInfo) {
        return appChkLst01Mapper.selectChkLstInfo(dto, tokenInfo);
    }

    @Override
    public void saveInspectResult(SaveInspectResultReq request,
                                  Map<String, MultipartFile> files,
                                  Map<String, Object> tokenInfo) {

        try {
            // 1) items JSON ЦФНЬ Ёц List<FileInfo>
            String itemsJson = request.getItems();
            List<FileInfo> items = new ArrayList<>();

            if (itemsJson != null && !itemsJson.isEmpty()) {
                JsonNode node = objectMapper.readTree(itemsJson);
                if (node.isArray()) {
                    for (JsonNode n : node) {
                        items.add(objectMapper.treeToValue(n, FileInfo.class));
                    }
                }
            }

            // 2) Map<String, MultipartFile> Ёц itemCd БтСи ИХЧЮ
            Pattern p = Pattern.compile("^files\\[(.+)]$");
            Map<String, MultipartFile> fileByItemCd = new HashMap<>();
            if (files != null) {
                for (Map.Entry<String, MultipartFile> e : files.entrySet()) {
                    Matcher m = p.matcher(e.getKey());
                    if (m.find()) {
                        fileByItemCd.put(m.group(1), e.getValue());
                    }
                }
            }

            String userId = tokenInfo.get("gv_userId").toString();

            // 3) items ИІ ЕЙИщМ­ "АЧКА" УГИЎ
            for (FileInfo it : items) {
                MultipartFile img = fileByItemCd.get(it.getItemCd());
                if (img == null || img.isEmpty()) {
                    continue; // ЦФРЯРЬ ОјДТ ЧзИёРК НКХЕ
                }

                // 3-1) АЧКА FileSaveQuery Л§МК (fileMgmtCd ОјРЬ)
                FileSaveQuery baseQuery = FileSaveQuery.builder()
                        .cmpnyCd(request.getCmpnyCd())
                        .userId(userId)
                        .siteCd(request.getSiteCd())
                        .fileType("100")          // РЯРЯСЁАЫ ХИРд
                        .itemCd(it.getItemCd())
                        .fileName(it.getFileName())
                        .build();

                // 3-2) АЧКА fileMgmtCd Л§МК
                String fileMgmtCd = fileMapper.selectFileMgmtCd(baseQuery);

                FileSaveQuery queryWithKey = baseQuery.toBuilder()
                        .fileMgmtCd(fileMgmtCd)
                        .build();

                // 3-3) АјХы FileService ПЁ "АЧКА" РњРх ПфУЛ
                fileService.saveFile(queryWithKey, img);

                // 3-4) ЧЪПфЧЯИщ ПЉБтМ­ КёСюДЯНКПы ХзРЬКэПЁ fileMgmtCd ПЌАш insert
                // appChkLst01Mapper.insertInspectFile(...);
            }

        } catch (Exception e) {
            log.error("saveInspectResult УГИЎ Сп ПРЗљ", e);
            throw new RuntimeException("РЯРЯСЁАЫ АсАњ РњРх Сп ПРЗљ", e);
        }
    }
}
