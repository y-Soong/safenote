<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.web.baim.baim01.mapper.Baim01Mapper">

    <select id="selectSchInfoList" parameterType="com.prafta.web.attd.attd01.dto.SchInfoListQry" resultType="com.prafta.web.attd.attd01.vo.SchInfo">
    /* Baim01Mapper.selectSchInfoList */
    SELECT
    	'' 							AS chk
    	, A.SITE_CD					AS siteCd
    	, A.SITE_NO					AS siteNo
    	, A.SITE_NM					AS siteNm
    	, A.CMPNY_CD				AS cmpnyCd
    	, A.ADDR_1					AS addr1
    	, A.ADDR_2					AS addr2
    	, A.ZIP_CODE				AS zipCode
    	, A.STR_DATE				AS strDate
    	, A.END_DATE				AS endDate
    	, A.USE_YN					AS useYn
    	, A.SITE_ADMIN_ID			AS siteAdminId
    	, B.USER_ID 				AS siteAdminNm
    	, A.TEL_NO					AS telNo
    	, IFNULL(A.GPS_RANGE, 0)	AS gpsRange
    	, A.SITE_DESC				AS siteDesc
   	FROM TB_SITE A
 		 LEFT JOIN TB_USER B
			ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.SITE_ADMIN_ID = B.USER_ID
            )
  	WHERE 1=1
  	  AND A.CMPNY_CD = #{token.gv_cmpnyCd}
  	  <if test="param.siteCd != null and param.siteCd != ''">
  	  	AND A.SITE_CD = #{param.siteCd}
  	  </if>
  	  <if test="param.siteNo != null and param.siteNo != ''">
  	  	AND A.SITE_NO = #{param.siteNo}
  	  </if>
  	  <if test="param.siteNm != null and param.siteNm != ''">
  	  	AND A.SITE_NM LIKE CONCAT('%', #{param.siteNm}, '%')
  	  </if>
  	  <if test="param.useYn != null and param.useYn != ''">
  	  	AND A.USE_YN = #{param.useYn}
  	  </if>
	</select>
</mapper>1