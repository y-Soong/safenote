<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.common.cmm.file.mapper.FileMapper">

	<select id="selectFileMgmtCd" parameterType="com.prafta.common.cmm.file.dto.FileSaveQuery" resultType="string">
    /* FileMapper."selectFileMgmtCd" */
    SELECT
	    CONCAT(
	    	#{fileType}
	    	,'-'
	    	,DATE_FORMAT(NOW(), '%Y%m%d')
	    	,'-'
	    	,FNC_CMM_SEQ_NEXTVAL(#{cmpnyCd}, CONCAT('FILE_MGMT_CD', '-', #{fileType}))
    	) AS FILE_MGMT_CD
	FROM DUAL
    </select>

	<insert id="insertFileInfo" parameterType="com.prafta.common.cmm.file.dto.FileInfoSave">
	/* FileMapper.insertFileInfo */	
    INSERT INTO TB_FILE_INFO (
    	CMPNY_CD
    	, FILE_MGMT_CD
    	, FILE_TYPE
    	, FILE_PATH
    	, FILE_EXT
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
   	)
   	VALUES(
   		#{param.cmpnyCd}
   		, #{param.fileMgmtCd}
   		, #{param.fileType}
   		, #{param.filePath}
   		, #{param.fileExt}
		, #{param.userId}
		, now()
		, #{param.userId}
		, now() 
   	)
   	ON DUPLICATE KEY UPDATE
	    USE_YN     		= VALUES(USE_YN)
	    , BAIM_VAL_D_NM = VALUES(BAIM_VAL_D_NM)
	    , SORT_IDX		= VALUES(SORT_IDX)
	    , USE_YN		= IFNULL(USE_YN, 'Y')
	    , VAL_D_INFO_1	= VALUES(VAL_D_INFO_1)
    	, VAL_D_INFO_2	= VALUES(VAL_D_INFO_2)
    	, VAL_D_DESC	= VALUES(VAL_D_DESC)
	    , UPDATE_NO   	= #{token.gv_userId}
	    , UPDATE_DATE 	= NOW()
	</insert>
</mapper>