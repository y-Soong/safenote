<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.common.cmm.login.mapper.LoginMapper">

    <select id="getLoginUser" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.getLoginUser */
	SELECT 
		A.CMPNY_CD
		, A.USER_ID
		, A.USER_NM
		, A.USER_PW
		, A.AUTH_CD
        , A.SITE_CD
        , B.SITE_NO
        , B.SITE_NM
		, A.MBL_NO
		, A.EMAIL
		, A.INSERT_NO
		, A.INSERT_DATE
		, A.UPDATE_NO
		, A.UPDATE_DATE
	FROM TB_USER A
         INNER JOIN TB_SITE B
			ON (
				A.CMPNY_CD = B.CMPNY_CD
			AND A.SITE_CD = B.SITE_CD
            )
	WHERE 1=1
	  AND A.USER_ID = #{userId}
	  AND A.USE_YN = 'Y'
    </select>

    <select id="lockUserRow" parameterType="com.prafta.common.cmm.login.dto.UserRowLock" resultType="map">
    /* LoginMapper.lockUserRow */
    SELECT USER_ID
	FROM TB_USER
	WHERE CMPNY_CD = #{cmpnyCd}
	  AND USER_ID  = #{userId}
	FOR UPDATE
    </select>
    
    <update id="revokeActiveToken" parameterType="com.prafta.common.cmm.login.dto.ActiveToken">
    /* LoginMapper.revokeActiveToken */
    UPDATE prafta.TB_AUTH_TOKEN
	SET REVOKED_YN='Y',
	    REVOKED_DTIME=NOW(),
	    UPDATE_NO=#{userId},
	    UPDATE_DATE=NOW()
	WHERE CMPNY_CD=#{cmpnyCd}
	  AND USER_ID=#{userId}
	  AND CLIENT_TYPE=#{clientType}
	  AND REVOKED_YN='N'
	  AND EXPIRE_DTIME > NOW()
    </update>
    
    <insert id="insertAuthToken" parameterType="com.prafta.common.cmm.login.dto.ActiveToken">
    /* LoginMapper.insertAuthToken */
    INSERT INTO prafta.TB_AUTH_TOKEN (
	    CMPNY_CD
	    , USER_ID
	    , TOKEN_ID
	    , CLIENT_TYPE
	    , REFRESH_TOKEN_HASH
	    , ISSUED_DTIME
	    , EXPIRE_DTIME
	    , REVOKED_YN
	    , REVOKED_DTIME
	    , INSERT_NO
	    , INSERT_DATE
	) VALUES (
	    #{cmpnyCd}
	    , #{userId}
	    , #{tokenId}
	    , #{clientType}
	    , #{refreshTokenHash}
	    , NOW()
	    , DATE_ADD(NOW(), INTERVAL #{expireDtime} DAY)
	    <!-- 
	    , #{expireDtime}
	     -->
	    , 'N'
	    , NULL,
	    #{userId}
	    , NOW()
	)
    </insert>
    
    <insert id="insertUserInfo" parameterType="com.prafta.common.cmm.login.dto.UserJoinReqDto">
    /* LoginMapper.insertUserInfo */
    INSERT INTO TB_USER (
    	CMPNY_CD
    	, USER_ID
    	, USER_NM
    	, USER_PW
    	, SITE_CD
    	, AUTH_CD
    	, MBL_NO
    	, EMAIL
    	, GENDER
    	, BIRTH_DT
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
   	)
   	VALUES(
   		#{cmpnyCd}
   		, #{userId}
   		, #{userNm}
   		, #{userPw}
   		, #{siteCd}
   		, IFNULL(#{authCd}, '99999')			<!-- 일반사용자권한 할당 -->
   		, FN_ENCRYPT(REPLACE(#{mblNo}, '-', ''))
   		, FN_ENCRYPT(#{email})
   		, #{gender}
   		, FN_ENCRYPT(#{birthDt})
   		, 'Y'
   		, 'SYSTEM'
   		, NOW()
   		, 'SYSTEM'
   		, NOW()
   	)
    </insert>
    
    <update id="revokeActiveTokenByClient" parameterType="com.prafta.common.cmm.login.dto.UserLogout">
    /* LoginMapper.revokeActiveTokenByClient */
	UPDATE TB_AUTH_TOKEN
       SET REVOKED_YN    = 'Y'
         , REVOKED_DTIME = NOW()
         , UPDATE_NO     = #{userId}
         , UPDATE_DATE   = NOW()
     WHERE CMPNY_CD      = #{cmpnyCd}
       AND USER_ID       = #{userId}
       AND CLIENT_TYPE   = #{clientType}
       AND REVOKED_YN    = 'N'
       AND EXPIRE_DTIME  > NOW()
       <if test="deviceId != null and deviceId != ''">
       AND DEVICE_ID     = #{deviceId}
       </if>
    </update>
    
    <update id="revokeAllActiveTokens" parameterType="com.prafta.common.cmm.login.dto.UserLogout">
    /* LoginMapper.revokeAllActiveTokens */
    UPDATE TB_AUTH_TOKEN
       SET REVOKED_YN    = 'Y'
         , REVOKED_DTIME = NOW()
         , UPDATE_NO     = #{userId}
         , UPDATE_DATE   = NOW()
     WHERE CMPNY_CD      = #{cmpnyCd}
       AND USER_ID       = #{userId}
       AND REVOKED_YN    = 'N'
       AND EXPIRE_DTIME  > NOW()
    </update>
    
    <insert id="insertUserSiteAuth" parameterType="com.prafta.common.cmm.login.dto.UserJoinReqDto">
    /* LoginMapper.insertUserSiteAuth */
    INSERT INTO TB_USER_SITE_AUTH (
    	CMPNY_CD
    	, USER_ID
    	, SITE_CD
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
    ) VALUES (
    	#{cmpnyCd}
    	, #{userId}
    	, #{siteCd}
    	, 'Y'
    	, #{userId}
    	, NOW()
    	, #{userId}
    	, NOW()
    )
    </insert>
    
    <select id="selectRequiredTermsList" resultType="map">
    /* LoginMapper.selectRequiredTermsList */
    SELECT 
		A.SYST_VAL_D_CD AS TERMS_ID
	    , A.SYST_VAL_D_NM AS TERMS_NM
	    , B.TERMS_VERSION AS TERMS_VERSION
	FROM TB_SYST_VAL_D A
	     INNER JOIN TB_TERMS B
			ON (
				A.SYST_VAL_D_CD = B.TERMS_ID
			AND B.REQUIRED_YN = 'Y'
	        AND B.USE_YN = 'Y'
	        )
	WHERE A.SYST_VAL_CD = 'SYS008'						/* 이용약관 코드 조회 */
    </select>
    
    <insert id="insertTermsUserAgrMgmt">
    /* LoginMapper.insertTermsUserAgrMgmt */
    INSERT INTO TB_TERMS_USER_AGR_MGMT (
    	USER_ID
    	, TERMS_ID
    	, TERMS_VERSION
    	, AGR_YN
    	, INSERT_NO
    	, INSERT_DATE
    )
    VALUES (
    	#{userId}
    	, #{termsId}
    	, #{termsVersion}
    	, #{agrYn}
    	, #{userId}
    	, NOW()
    )
    </insert>
    
    <select id="selectUserTermsAgrChk" parameterType="com.prafta.common.cmm.login.dto.LoginReqDto" resultType="map">
    /* LoginMapper.selectUserTermsAgrChk */
    SELECT
		A.*
	FROM
	(
	    SELECT 
			A.TERMS_ID
		    , CASE
				WHEN A.TERMS_VERSION = B.TERMS_VERSION
					THEN 'Y'
				ELSE 'N'
			END USER_TERMS_AGR_YN    
		FROM TB_TERMS A
		     LEFT OUTER JOIN TB_TERMS_USER_AGR_MGMT B
				ON (
					A.TERMS_ID = B.TERMS_ID
				AND A.TERMS_VERSION = B.TERMS_VERSION
		        AND B.USER_ID = #{userId}
		        )
		WHERE 1=1
		  AND A.USE_YN = 'Y'
	) A
	WHERE A.USER_TERMS_AGR_YN = 'N'
    </select>
    
    <update id="mergeAuthMenuInfo">
	/* LoginMapper.mergeAuthMenuInfo */
	INSERT INTO TB_TERMS_USER_AGR_MGMT (
		USER_ID
		, TERMS_ID
		, TERMS_VERSION
		, AGR_YN
		, INSERT_NO
		, INSERT_DATE
	) 
	SELECT 
		#{token.gv_userId} AS USER_ID
	    , TERMS_ID
	    , TERMS_VERSION
	    , 'Y'
	    , #{token.gv_userId} AS INSERT_NO
	    , NOW() AS INSERT_DATE
	FROM TB_TERMS
	WHERE 1=1
	  AND TERMS_ID = #{param.systValDCd}
    </update>
</mapper>