	public SiteGroupNodeListRes selectSiteGroupNodeList(SiteGroupNodeListReq dto, Map<String, Object> tokenInfo) {
		SiteGroupNodeListQry reqdDto = SiteGroupNodeListQry.builder()
										.siteCd(dto.getSiteCd())
										.build();
		
		SiteGroupNodeListRes retDto = null;
		
		List<SiteGroupNode> siteGroupNodeList = baim06Mapper.selectSiteGroupNodeList(reqdDto, tokenInfo);
		
		if(siteGroupNodeList != null && siteGroupNodeList.size() > 0) {
			retDto = SiteGroupNodeListRes.builder()
											.siteGroupNodeList(siteGroupNodeList)
											.build();
		}
		
		return retDto;
	}
	
	public void saveSiteGroupNode(List<SiteGroupNodeReq> dtoList, Map<String, Object> tokenInfo) {
		
		for(SiteGroupNodeReq dto : dtoList) {
			
			SiteGroupNodeSave reqDto = SiteGroupNodeSave.builder()
										.siteCd(dto.getSiteCd())
										.nodeId(dto.getNodeId())
										.nodeNm(dto.getNodeNm())
										.nodeType(dto.getNodeType())
										.parentNodeId(dto.getParentNodeId())
										.selfAttdApprvYn(dto.getSelfAttdApprvYn())
										.build();
			
			baim06Mapper.saveSiteGroupNode(reqDto, tokenInfo);
		}
	}
	
	public void deleteSiteGroupNode(SiteGroupNodeReq dto, Map<String, Object> tokenInfo) {
		SiteGroupNodeDelete reqDto = SiteGroupNodeDelete.builder()
										.siteCd(dto.getSiteCd())
										.nodeId(dto.getNodeId())
										.build();
		
		baim06Mapper.deleteSiteGroupNode(reqDto, tokenInfo);
	}
}
