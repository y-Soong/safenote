	}
	
	public Map<String, Object> selectUserIdDupleChk(BaseinfoReqDto dto) {
		return baseinfoMapper.selectUserIdDupleChk(dto);
	}
	
	public void insertSmsAuthReq(BaseinfoReqDto dto) {
		int mblCnt = baseinfoMapper.selectMblUniqChk(dto);
		
		if(mblCnt > 1) {
			throw new CmmApiException("РЬЙЬ ЕюЗЯЕШ ШоДыЦљЙјШЃРдДЯДй.\n ШЎРЮ ШФ ДйНУ НУЕЕЧиСжММПф.");
		}
		
