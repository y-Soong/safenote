	}
	
	public int updateSmsAuthReq(BaseinfoReqDto dto) {
		return baseinfoMapper.updateSmsAuthReq(dto);
	}
	
	public Map<String, Object> selectCertNoSmsId(BaseinfoReqDto dto) {
