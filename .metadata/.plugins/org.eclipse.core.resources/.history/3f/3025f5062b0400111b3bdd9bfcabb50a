<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.web.user.user01.mapper.User01Mapper">

    <select id="selectUserInfoList" parameterType="com.prafta.web.user.user01.dto.UserInfoListQry" resultType="com.prafta.web.user.user01.vo.UserInfo">
    /* User01Mapper.selectUserInfoList */
	SELECT 
		'' 								AS chk
		, A.CMPNY_CD					AS cmpnyCd
        , A.USER_ID						AS userId
        , A.USER_NM						AS userNm
        , A.AUTH_CD						AS authCd
        , A.SITE_CD						AS siteCd
        , A.NODE_CD						AS nodeCd
        , C.SITE_NM						AS siteNm
        , FN_DECRYPT(A.MBL_NO) 			AS mblNo
        , FN_DECRYPT(A.BIRTH_DT) 		AS birthDt
        , FN_DECRYPT(A.EMAIL) 			AS email
        , A.GENDER						AS gender
        , A.USE_YN						AS useYn
        , IFNULL(B.SITE_NM_LIST, '') 	AS siteNmList
	FROM TB_USER A
		 LEFT JOIN (
			SELECT 
				A.USER_ID
				, GROUP_CONCAT(B.SITE_NM ORDER BY B.SITE_CD SEPARATOR ',') AS SITE_NM_LIST
			FROM TB_USER_SITE_AUTH A
			     INNER JOIN TB_SITE B
					ON (
						A.CMPNY_CD = B.CMPNY_CD
					AND A.SITE_CD = B.SITE_CD
					)
			WHERE A.USE_YN = 'Y'
			GROUP BY A.USER_ID
		) B
		ON B.USER_ID = A.USER_ID
		INNER JOIN TB_SITE C
		ON (
			A.CMPNY_CD = C.CMPNY_CD
		AND A.SITE_CD = C.SITE_CD
           AND C.USE_YN = 'Y'
           )
	WHERE 1=1
	  AND A.CMPNY_CD = #{token.gv_cmpnyCd}
	  AND A.AUTH_CD != '999'				/* 시스템관리자 권한 제외 */
	  <if test="param.userNm != null and param.userNm != ''">
	  	AND A.USER_NM LIKE CONCAT('%', #{userNm}, '%')
	  </if>
	  <if test="param.userId != null and param.userId != ''">
	  	AND A.USER_ID = #{param.userId}
	  </if>
	  <if test="param.useYn != null and param.useYn != ''">
	  	AND A.USE_YN = #{param.useYn}
	  </if>
	  <if test="param.siteCd != null and param.siteCd != ''">
	  	AND A.SITE_CD = #{param.siteCd}
	  </if>
    </select>
    
	<update id="updateUserPw" parameterType="com.prafta.web.user.user01.dto.UserPasswdSave">
	/* User01Mapper.updateUserPw */
	UPDATE
		TB_USER
	SET
		USER_PW = #{userPw}
	WHERE 1=1
	  AND CMPNY_CD = #{cmpnyCd}
	  AND USER_ID = #{userId}
	</update>
	
	<insert id="mergeUserInfo">
	/* User01Mapper.updateUserInfo */
	UPDATE TB_USER 
	SET 
		SITE_CD = #{param.siteCd}
		, AUTH_CD = #{param.authCd}
		, MBL_NO = FN_ENCRYPT(REPLACE(#{param.mblNo}, '-', ''))
		, EMAIL = FN_ENCRYPT(#{param.email})
		, GENDER = #{param.gender}
		, BIRTH_DT = FN_ENCRYPT(#{param.birthDt})
		, USE_YN = IFNULL(#{param.useYn}, 'Y')
		, UPDATE_NO = #{token.gv_userId}
		, UPDATE_DATE = NOW()
	WHERE 1=1
	  AND CMPNY_CD = #{param.cmpnyCd}
	  AND USER_ID = #{param.userId}
	</insert>
	
	<select id="selectUserSiteInfo" parameterType="com.prafta.web.user.user01.dto.User01ReqDto" resultType="map">
    /* User01Mapper.selectUserSiteInfo */
    SELECT
    	A.CMPNY_CD 	AS cmpnyCD
    	, A.USER_ID	AS userId
    	, A.SITE_CD	AS siteCd
    	, A.USE_YN 	AS useYn 
	FROM TB_USER A
	WHERE A.CMPNY_CD = #{param.cmpnyCd}
	  AND A.USER_ID = #{param.userId}
    </select>
    
    <update id="deleteUserSiteAuth">
    /* User01Mapper.deleteUserSiteAuth */
    UPDATE TB_USER_SITE_AUTH
   	SET 
   		USE_YN = 'N'
   		, UPDATE_NO = #{token.gv_userId}
  		, UPDATE_DATE = NOW()
	WHERE CMPNY_CD = #{param.cmpnyCd}
	  AND USER_ID = #{param.userId}   		
    	
    </update>
    
    <update id="insertUserSiteAuth">
    /* User01Mapper.insertUserSiteAuth */
    INSERT INTO TB_USER_SITE_AUTH (
    	CMPNY_CD
    	, USER_ID
    	, SITE_CD
    	, USE_YN
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
    )
    VALUES (
    	#{param.cmpnyCd}
    	, #{param.userId}
    	, #{param.siteCd}
    	, IFNULL(#{param.useYn}, 'Y')
    	, #{token.gv_userId}
    	, NOW()
    	, #{token.gv_userId}
    	, NOW()
    )
    ON DUPLICATE KEY UPDATE
	    USE_YN        = VALUES(USE_YN)
	    , UPDATE_NO   = VALUES(UPDATE_NO)
	    , UPDATE_DATE = VALUES(UPDATE_DATE)
    </update>
</mapper>