<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.prafta.web.baim.baim02.mapper.Baim02Mapper">

    <select id="selectCompCmmCodeMList" parameterType="com.prafta.web.baim.baim02.dto.CompCmmCodeMListQry" resultType="com.prafta.web.baim.baim02.vo.CompCmmCodeM">
    /* Baim02Mapper.selectCompCmmCodeMList */
    SELECT
    	'' 				AS chk
    	, CMPNY_CD		AS cmpnyCd
    	, BAIM_VAL_CD	AS baimValCd
    	, BAIM_VAL_NM	AS baimValNm
    	, USE_YN		AS useYn
    	, VAL_INFO_1	AS valInfo1
    	, VAL_INFO_2	AS valInfo2
    	, VAL_DESC		AS valDesc
   	FROM TB_BAIM_VAL_M
   	WHERE 1=1
   	  AND CMPNY_CD = #{token.gv_cmpnyCd}
   	  AND USE_YN = 'Y'
   	  <if test="param.sr_codeNm != null and param.sr_codeNm != ''">
   	  	AND BAIM_VAL_NM LIKE CONCAT('%', #{param.sr_codeNm}, '%')
   	  </if>
	</select>
	
	<select id="selectCompCmmCodeDList" parameterType="com.prafta.web.baim.baim02.dto.CompCmmCodeDListQry" resultType="com.prafta.web.baim.baim02.vo.CompCmmCodeD">
    /* Baim02Mapper.selectCompCmmCodeDList */
    SELECT
    	'' 					AS chk
    	, A.CMPNY_CD		AS cmpnyCd
    	, A.BAIM_VAL_CD		AS baimValCd
    	, B.BAIM_VAL_D_CD	AS baimValDCd
    	, B.BAIM_VAL_D_NM 	AS baimValDNm
    	, B.SORT_IDX		AS sortIdx
    	, B.USE_YN			AS useYn
    	, B.VAL_D_INFO_1	AS valDInfo1
    	, B.VAL_D_INFO_2	AS valDInfo2
    	, B.VAL_D_DESC		AS valDDesc
   	FROM TB_BAIM_VAL_M A
   		 INNER JOIN TB_BAIM_VAL_D B
   		 	ON (
   		 		A.CMPNY_CD = B.CMPNY_CD
 		 	AND A.BAIM_VAL_CD = B.BAIM_VAL_CD
 		 	AND B.USE_YN = 'Y'
   		 	)
   	WHERE 1=1
   	  AND A.CMPNY_CD = #{token.gv_cmpnyCd}
   	  AND A.USE_YN = 'Y'
   	  AND A.BAIM_VAL_CD = #{param.sr_codeCd}
	</select>
	
	<insert id="mergeCmmCodeDetailInfo">
	/* Baim02Mapper.mergeCmmCodeDetailInfo */	
    INSERT INTO TB_BAIM_VAL_D (
    	CMPNY_CD
    	, BAIM_VAL_CD
    	, BAIM_VAL_D_CD
    	, BAIM_VAL_D_NM
    	, SORT_IDX
    	, USE_YN
    	, VAL_D_INFO_1
    	, VAL_D_INFO_2
    	, VAL_D_DESC
    	, INSERT_NO
    	, INSERT_DATE
    	, UPDATE_NO
    	, UPDATE_DATE
   	)
   	VALUES(
   		#{token.gv_cmpnyCd}
   		, #{param.baimValCd}
   		, IFNULL(#{param.baimValDCd}, FNC_CMM_SEQ_NEXTVAL(#{token.gv_cmpnyCd}, #{param.baimValCd}))
   		, #{param.baimValDNm}
   		, #{param.sortIdx}
		, #{param.useYn}
		, #{param.valDInfo1}
		, #{param.valDInfo2}
		, #{param.valDDesc}
		, #{token.gv_userId}
		, now()
		, #{token.gv_userId}
		, now() 
   	)
   	ON DUPLICATE KEY UPDATE
	    USE_YN     		= VALUES(USE_YN)
	    , BAIM_VAL_D_NM = VALUES(BAIM_VAL_D_NM)
	    , SORT_IDX		= VALUES(SORT_IDX)
	    , USE_YN		= IFNULL(#{param.useYn}, 'Y')
	    , VAL_D_INFO_1	= VALUES(VAL_D_INFO_1)
    	, VAL_D_INFO_2	= VALUES(VAL_D_INFO_2)
    	, VAL_D_DESC	= VALUES(VAL_D_DESC)
	    , UPDATE_NO   	= #{token.gv_userId}
	    , UPDATE_DATE 	= NOW()
	</insert>
	
	<update id="deleteCmmCodeDetailInfo">
	/* Baim02Mapper.mergeCmmCodeDetailInfo */
	UPDATE TB_BAIM_VAL_D 
	SET USE_YN = 'N'
		, UPDATE_NO = #{token.gv_userId}
		, UPDATE_DATE = now()
	WHERE CMPNY_CD = #{token.gv_cmpnyCd}
	  AND BAIM_VAL_CD = #{param.baimValCd}
	  AND BAIM_VAL_D_CD = #{param.baimValDCd}
	
	</update>
</mapper>